{
  "name": "web",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently --names next,ws --prefix-colors blue,green \"next dev\" \"tsx watch ws-server.ts\"",
    "build": "next build",
    "start": "cross-env HOSTNAME=localhost node .next/standalone/apps/web/server.js",
    "start:standalone": "node scripts/start-standalone.mjs",
    "lint": "eslint --max-warnings 0",
    "check-types": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@repo/ui": "*",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.1.18",
    "@tanstack/react-query": "^5.90.21",
    "autoprefixer": "^10.4.24",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "ioredis": "^5.9.2",
    "next": "16.1.5",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.4.31",
    "prisma": "^7.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.1.18",
    "uuid": "^13.0.0",
    "ws": "^8.18.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.16.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.1.2",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "happy-dom": "^20.6.1",
    "jsdom": "^28.1.0",
    "tsx": "^4.21.0",
    "typescript": "5.9.2",
    "vitest": "^4.0.18"
  }
}
